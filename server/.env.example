# yc-voice-agent-hackathon - Environment Variables
# Copy this file to .env and fill in your API keys

# Twilio (Transport)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Gradium (TTS)
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# === ALL-NVIDIA voice pipeline: Parakeet STT -> Nemotron LLM -> Magpie TTS ===
# Language: "en-US" | es-US | fr-FR | de-DE | it-IT | hi-IN | ja-JP to run one
# language, or "multi" so callers can speak ANY supported language (STT
# auto-detects via parakeet-1.1b-rnnt-multilingual, LLM mirrors it).
AGENT_LANGUAGE=en-US
# MAGPIE_LANGUAGE=en-US   # Magpie reply language when AGENT_LANGUAGE=multi
# STT: "nvidia" (Parakeet via NVIDIA NIM, reliable) | "nvidia_ws" (shared WS box,
#      flaky under load) | "gradium" (non-NVIDIA fallback)
STT_PROVIDER=nvidia
NVIDIA_ASR_URL=          # only for STT_PROVIDER=nvidia_ws

# TTS: "nvidia" (Magpie magpie-tts-multilingual via Riva/NIM) or "gradium" (fallback)
TTS_PROVIDER=nvidia
MAGPIE_VOICE=Magpie-Multilingual.EN-US.Aria
# Magpie auth reuses NEMOTRON_LLM_API_KEY (nvapi-) unless NVIDIA_API_KEY is set.
# Point at a self-hosted Magpie NIM on AWS to keep every layer on AWS:
# NVIDIA_API_KEY=
# NVIDIA_TTS_SERVER=grpc.nvcf.nvidia.com:443
# NVIDIA_TTS_USE_SSL=true
# MAGPIE_FUNCTION_ID=877104f7-e885-42b9-8de8-f6e4c6303969
# MAGPIE_MODEL=magpie-tts-multilingual

# NVIDIA Nemotron LLM
NEMOTRON_LLM_URL=
NEMOTRON_ENABLE_THINKING=

# OpenAI (Local Test Harness)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Latency / turn-taking tuning (optional; defaults shown)
LLM_MAX_TOKENS=200
LLM_TEMPERATURE=0.4
VAD_STOP_SECS=0.5
VAD_CONFIDENCE=0.7
ALLOW_INTERRUPTIONS=true

# Post-call logging (optional). If INTAKE_S3_BUCKET is unset the follow-up queue
# is still built and logged; only the S3 upload is skipped.
INTAKE_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
# Optional live tool-event log path used by the Streamlit dashboard.
INTAKE_TOOL_EVENTS_PATH=
# Optional remote tool-events API (FastAPI + SQLite) for live dashboard polling.
# Set both the dashboard and deployed agent to the same ngrok URL.
TOOL_EVENTS_API_URL=
TOOL_EVENTS_API_TOKEN=
# Optional Bedrock RAG for statute-of-limitations lookups (falls back to a static table)
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_MODEL_ARN=

# Cekura Observability (optional). After each call, transcript is sent to Cekura
# when both values are set. Do not commit real keys — set in Pipecat Cloud secrets.
CEKURA_API_KEY=
CEKURA_AGENT_ID=18019
CEKURA_PROJECT_ID=5853

# Post-call eval loop (auto-score call, patch prompt on metric failures)
CEKURA_EVAL_LOOP_ENABLED=true
CEKURA_EVAL_LOOP_SYNC_AGENT=true
# Optional: name:metric_id,name:metric_id
# CEKURA_TRACKED_METRIC_IDS=Agent Asked What Happened:147963,Agent Asked About Medical Attention:147964,Agent Asked About Legal Representation:147965
