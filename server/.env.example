# yc-voice-agent-hackathon - Environment Variables
# Copy this file to .env and fill in your API keys

# Twilio (Transport)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Gradium (TTS)
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# NVIDIA Nemotron ASR (STT)
NVIDIA_ASR_URL=

# NVIDIA Nemotron LLM
NEMOTRON_LLM_URL=
NEMOTRON_ENABLE_THINKING=

# OpenAI (Local Test Harness)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Latency / turn-taking tuning (optional; defaults shown)
LLM_MAX_TOKENS=200
LLM_TEMPERATURE=0.4
VAD_STOP_SECS=0.5
VAD_CONFIDENCE=0.7
ALLOW_INTERRUPTIONS=true