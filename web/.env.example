# FirstCall web app — Supabase (frontend uses the ANON key only; never the
# service_role key, which is server-side and bypasses RLS).
#
# Leave these unset to run in local-demo mode (mock data + localStorage auth).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional live tool-events API (same URL + token as the deployed agent / Streamlit).
# When set, /app/live polls this for in-call tool activity. Otherwise uses Supabase model_events.
VITE_TOOL_EVENTS_API_URL=
VITE_TOOL_EVENTS_API_TOKEN=

# Local dev only — proxied via vite /api/cekura (never use VITE_ prefix; key must stay server-side).
# On Vercel, set CEKURA_API_KEY as a server env var (not VITE_).
CEKURA_API_KEY=
CEKURA_PROJECT_ID=5853
CEKURA_AGENT_ID=18019

# Server-side (Vercel env, NEVER VITE_) — Twilio number auto-provisioning via
# /api/provision-number, and the Voice webhook /api/twiml.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
PIPECAT_SERVICE_HOST=flower-bot.saibha123
# Supabase server keys so the provisioning fn can write profiles.twilio_phone.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
